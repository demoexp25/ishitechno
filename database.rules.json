{
  "rules": {
    ".read": false,
    ".write": false,

    "users": {
      "$uid": {
        ".read":  "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('role').val() === 'admin')",
        ".write": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('role').val() === 'admin')",
        ".validate": "newData.hasChildren(['name','email','role'])",
        "role": {
          ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
        },
        "disabled": {
          ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
        }
      }
    },

    "devices": {
      ".read": "auth != null",
      "$deviceId": {
        ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('devices').child($deviceId).child('ownerUid').val() === auth.uid)",
        ".validate": "newData.hasChildren(['secretKey'])"
      }
    },

    "locations": {
      "$deviceId": {
        ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('devices').child($deviceId).child('ownerUid').val() === auth.uid)",
        ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
      }
    },

    "history": {
      "$deviceId": {
        ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('devices').child($deviceId).child('ownerUid').val() === auth.uid)",
        ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
        ".indexOn": ["timestamp"]
      }
    },

    "alerts": {
      ".indexOn": ["uid", "deviceId", "resolved"],
      "$alertId": {
        ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || data.child('uid').val() === auth.uid)",
        ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || data.child('uid').val() === auth.uid || newData.child('uid').val() === auth.uid)"
      }
    },

    "geofences": {
      "$geofenceId": {
        ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || data.child('uid').val() === auth.uid)",
        ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || data.child('uid').val() === auth.uid || newData.child('uid').val() === auth.uid)"
      }
    }
  }
}
